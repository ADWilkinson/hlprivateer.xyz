{
  "id": null,
  "title": "HL Privateer Overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "type": "stat",
      "title": "Runtime Cycles",
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "rate(hlp_runtime_cycles_total[5m])"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "timeseries",
      "title": "Risk Decisions by Result",
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "increase(hlp_runtime_risk_decisions_total[5m])"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 16,
        "x": 8,
        "y": 0
      },
      "id": 2
    },
    {
      "type": "timeseries",
      "title": "WS Connections",
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "hlp_ws_connections"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 6
      },
      "id": 3
    }
  ],
  "time": {
    "from": "now-6h",
    "to": "now"
  }
}
