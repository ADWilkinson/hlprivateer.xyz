# Core
NODE_ENV=development
LOG_LEVEL=info
TZ=UTC

# Public endpoints (used by API CORS + web build-time endpoints)
PUBLIC_BASE_URL=https://hlprivateer.xyz
API_BASE_URL=https://api.hlprivateer.xyz
WS_BASE_URL=wss://ws.hlprivateer.xyz
NEXT_PUBLIC_API_BASE_URL=https://api.hlprivateer.xyz
NEXT_PUBLIC_WS_BASE_URL=wss://ws.hlprivateer.xyz

# API
PORT=4000
API_RATE_LIMIT_MAX=120
API_RATE_LIMIT_WINDOW_MS=60000

# Auth (operator)
JWT_SECRET=
# REQUIRED in production: set a strong random value (or use JWT_SECRET_FILE).
JWT_SECRET_FILE=
OPERATOR_LOGIN_SECRET=
# REQUIRED in production: used to bootstrap operator login (or use OPERATOR_LOGIN_SECRET_FILE).
OPERATOR_LOGIN_SECRET_FILE=
OPERATOR_MFA_REQUIRED=true
OPERATOR_ADMIN_USERS=admin@local

# Redis (event bus + cache)
REDIS_URL=redis://127.0.0.1:6379
REDIS_STREAM_PREFIX=hlp

# Database (required for production/live operation; avoid using DRY_RUN for normal trading)
POSTGRES_PASSWORD=CHANGE_ME
DATABASE_URL=postgres://privateer:CHANGE_ME@127.0.0.1:5432/privateer
DATABASE_URL_FILE=

# Runtime loop
CYCLE_MS=5000
DRY_RUN=false

# Hyperliquid endpoints
HL_WS_URL=wss://api.hyperliquid.xyz/ws
HL_WS_URL_FILE=
HL_INFO_URL=
HL_INFO_URL_FILE=
HL_API_URL=
HL_API_URL_FILE=
HL_IS_TESTNET=false
HL_REQUEST_TIMEOUT_MS=10000

# Risk defaults
RISK_MAX_LEVERAGE=2
# Preferred sizing target for agent layers (runtime still enforces RISK_MAX_LEVERAGE as a hard cap).
RISK_TARGET_LEVERAGE=2
RISK_MAX_DRAWDOWN_PCT=5
RISK_MAX_SLIPPAGE_BPS=20
RISK_MAX_NOTIONAL_USD=10000
RISK_STALE_DATA_MS=3000
RISK_LIQUIDITY_BUFFER_PCT=1.1
RISK_NOTIONAL_PARITY_TOLERANCE=0.015
# Strategy sizing and floor-level safety settings.
AGENT_TARGET_NOTIONAL_USD=100
RUNTIME_FLAT_DUST_NOTIONAL_USD=100
RUNTIME_MIN_LIVE_ACCOUNT_VALUE_USD=100
RUNTIME_METRICS_PORT=9400

# Live mode enable gate (runtime will refuse live unless explicitly approved)
HL_PRIVATE_KEY=
HL_PRIVATE_KEY_FILE=
ENABLE_LIVE_OMS=false
LIVE_MODE_APPROVED=false
LIVE_RECONCILE_OPEN_ORDER_MAX_AGE_MS=60000

# WS gateway
WS_PORT=4100
WS_ALLOW_INSECURE_TOKENS=false

# x402 (paid agent endpoints)
X402_ENABLED=true
X402_PROVIDER=facilitator
X402_VERIFIER_SECRET=
# REQUIRED in production: set a strong random value (or use X402_VERIFIER_SECRET_FILE).
X402_VERIFIER_SECRET_FILE=
X402_FACILITATOR_URL=https://facilitator.payai.network
X402_NETWORK=eip155:8453
X402_PAYTO=CHANGE_ME
X402_PRICE_STREAM_SNAPSHOT="\\$0.01"
X402_PRICE_ANALYSIS_LATEST="\\$0.01"
X402_PRICE_ANALYSIS_HISTORY="\\$0.01"
X402_PRICE_POSITIONS="\\$0.01"
X402_PRICE_ORDERS="\\$0.01"

# Agent runner (LLM roles that publish tape + proposals)
AGENT_ID=privateer-floor
AGENT_LLM=codex
# Agent CLI auth mounts (container runtime paths)
# - For local development, mount host auth dirs so claude/codex can authorize.
AGENT_RUNNER_CLAUDE_DIR=/home/dappnode/.claude
AGENT_RUNNER_CODEX_DIR=/home/dappnode/.codex
AGENT_RUNNER_CLAUDE_CFG_DIR=/home/dappnode/.config/claude
CLAUDE_CLI_PATH=/usr/local/bin/claude
CODEX_CLI_PATH=/usr/local/bin/codex
# CLI auth tokens (optional; empty values are skipped)
OPENAI_API_KEY=
OPENAI_API_BASE_URL=
OPENAI_ORG_ID=
OPENAI_API_KEY_FILE=
ANTHROPIC_API_KEY=
ANTHROPIC_API_KEY_FILE=
CLAUDE_CODE_API_KEY=
CLAUDE_CODE_API_KEY_FILE=
OPENCLAW_HOME=/home/dappnode/.openclaw/workspace
OPENCLAW_MARKET_DATA_PATH=/home/dappnode/.openclaw/workspace/skills/market-data/market-data.js
OPENCLAW_TWITTER_CREDS_PATH=/home/dappnode/.openclaw/workspace/.twitter_creds.json
# External intel (agent-runner pulls in structured context before research/strategy runs).
AGENT_INTEL_ENABLED=true
AGENT_INTEL_TWITTER_ENABLED=true
AGENT_INTEL_TWITTER_MAX_RESULTS=8
AGENT_INTEL_TIMEOUT_MS=8000
# Optional override; otherwise agent-runner reads OPENCLAW_TWITTER_CREDS_PATH.
TWITTER_BEARER_TOKEN=
#
# Scheduling knobs
# - Proposal loop drives discretionary long/short decision output at least hourly.
AGENT_PROPOSAL_INTERVAL_MS=3600000
# - Directive loop controls strategy refresh/cadence for discretionary regimes.
AGENT_DIRECTIVE_INTERVAL_MS=3600000
AGENT_ANALYSIS_INTERVAL_MS=3600000
AGENT_RESEARCH_INTERVAL_MS=3600000
AGENT_MIN_REBALANCE_LEG_USD=100
AGENT_RISK_INTERVAL_MS=3600000
AGENT_OPS_INTERVAL_MS=5000
AGENT_UNIVERSE_SIZE=6
AGENT_UNIVERSE_CANDIDATE_LIMIT=240
AGENT_UNIVERSE_REFRESH_MS=3600000
CLAUDE_MODEL=opus
CODEX_MODEL=gpt-5.3-codex-spark
CODEX_REASONING_EFFORT=xhigh
AGENT_FEATURE_WINDOW_MIN=240
AGENT_FEATURE_CONCURRENCY=6

# Audit/observability journaling + alerting.
AGENT_JOURNAL_ENABLED=true
AGENT_JOURNAL_PATH=journals
AGENT_GITHUB_JOURNAL_ENABLED=false
AGENT_GITHUB_JOURNAL_PATH=journals
AGENT_GITHUB_JOURNAL_FLUSH_INTERVAL_MS=0
GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
GITHUB_JOURNAL_BRANCH=main
GITHUB_API_URL=https://api.github.com
GITHUB_JOURNAL_TIMEOUT_MS=10000
DISCORD_WEBHOOK_ENABLED=false
DISCORD_WEBHOOK_URL=
DISCORD_WEBHOOK_ACTIONS=analysis.report,agent.error,agent.proposal,agent.proposal.invalid,research.report,risk.report,risk.decision,intel.refresh,strategist.directive,universe.selected
DISCORD_WEBHOOK_COOLDOWN_MS=60000
DISCORD_WEBHOOK_TIMEOUT_MS=5000

# CoinGecko Pro (optional; enriches universe selection + analysis context)
COINGECKO_API_KEY=
COINGECKO_BASE_URL=https://pro-api.coingecko.com/api/v3
COINGECKO_TIMEOUT_MS=2000

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4317
