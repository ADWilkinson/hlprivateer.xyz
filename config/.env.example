# Core
NODE_ENV=production
LOG_LEVEL=info
APP_ENV=prod
TZ=UTC

# Networking
PUBLIC_BASE_URL=https://hlprivateer.xyz
API_BASE_URL=https://api.hlprivateer.xyz
WS_BASE_URL=wss://ws.hlprivateer.xyz
NEXT_PUBLIC_API_BASE_URL=https://api.hlprivateer.xyz
NEXT_PUBLIC_WS_BASE_URL=wss://ws.hlprivateer.xyz

# Database
DATABASE_URL=postgres://privateer:CHANGE_ME@127.0.0.1:5432/privateer
DATABASE_POOL_MAX=25

# Redis (event bus + cache)
REDIS_URL=redis://127.0.0.1:6379
REDIS_STREAM_PREFIX=hlp

# Auth / JWT
JWT_ISSUER=hlprivateer
JWT_AUDIENCE=hlprivateer-operator
JWT_PRIVATE_KEY_PATH=/etc/hlprivateer/keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=/etc/hlprivateer/keys/jwt-public.pem
JWT_SECRET=replace-me
JWT_SECRET_FILE=

# Hyperliquid
HL_ENV=mainnet
HL_API_URL=https://api.hyperliquid.xyz
HL_ACCOUNT_ADDRESS=0xCHANGE_ME
HL_PRIVATE_KEY_PATH=/etc/hlprivateer/keys/hyperliquid.key
HL_MAX_ORDERS_PER_MIN=120

# Risk defaults
RISK_MAX_LEVERAGE=2
RISK_MAX_DRAWDOWN_PCT=5
RISK_MAX_SLIPPAGE_BPS=20
RISK_MAX_NOTIONAL_USD=10000
RISK_STALE_DATA_MS=3000
LIVE_MODE_APPROVED=false

# x402 payments
X402_ENABLED=true
X402_NETWORK=base
X402_VERIFIER_URL=https://x402verifier.example
X402_MERCHANT_ADDRESS=0xCHANGE_ME
X402_SIGNING_KEY_PATH=/etc/hlprivateer/keys/x402-signing.key
X402_VERIFIER_SECRET=x402-secret
X402_VERIFIER_SECRET_FILE=

# Alternative file-backed secret sources (systemd credentials / SOPS bootstrap)
DATABASE_URL_FILE=
HL_WS_URL_FILE=
LIVE_OMS_API_KEY_FILE=

# Firebase (optional mirror/alerts)
FIREBASE_PROJECT_ID=privateer-xbt
FIREBASE_API_KEY=REDACTED_GOOGLE_API_KEY
FIREBASE_AUTH_DOMAIN=privateer-xbt.firebaseapp.com
FIREBASE_STORAGE_BUCKET=privateer-xbt.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=27673906848
FIREBASE_APP_ID=1:27673906848:web:b6b1db636eca9347c003c5
FIREBASE_MEASUREMENT_ID=G-8ST68MBEYW
NEXT_PUBLIC_FIREBASE_PROJECT_ID=privateer-xbt
NEXT_PUBLIC_FIREBASE_API_KEY=REDACTED_GOOGLE_API_KEY
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=privateer-xbt.firebaseapp.com
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=privateer-xbt.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=27673906848
NEXT_PUBLIC_FIREBASE_APP_ID=1:27673906848:web:b6b1db636eca9347c003c5
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-8ST68MBEYW

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4317
PROMETHEUS_PUSHGATEWAY=http://127.0.0.1:9091
LOKI_URL=http://127.0.0.1:3100
