{
  "name": "hlprivateer.xyz",
  "private": true,
  "version": "0.1.0",
  "description": "Self-hosted, TypeScript-first, agentic Hyperliquid trading platform",
  "packageManager": "bun@1.2.19",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "bash scripts/workspace.sh dev --parallel",
    "build": "bash scripts/workspace.sh build",
    "lint": "bash scripts/workspace.sh lint",
    "test": "bash scripts/workspace.sh test",
    "typecheck": "bash scripts/workspace.sh typecheck",
    "format": "echo 'format not wired; run package-specific formatters as needed'",
    "deploy:web:firebase": "cd apps/web && bun run build:firebase && bunx firebase-tools deploy --only hosting",
    "secrets:decrypt": "bash scripts/secrets/decrypt.sh",
    "secrets:rotate": "bash scripts/secrets/rotate.sh",
    "secrets:rotate:print": "bash scripts/secrets/rotate.sh --print"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "@types/pg": "^8.15.4",
    "drizzle-orm": "^0.45.1",
    "firebase": "^12.9.0",
    "pg": "^8.16.3",
    "tsx": "^4.19.2",
    "turbo": "^2.5.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8",
    "zod": "^3.24.1"
  }
}
