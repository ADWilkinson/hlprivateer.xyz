{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@hl/privateer-contracts": ["./packages/contracts/src"],
      "@hl/privateer-event-bus": ["./packages/event-bus/src"],
      "@hl/privateer-risk-engine": ["./packages/risk-engine/src"],
      "@hl/privateer-plugin-sdk": ["./packages/plugin-sdk/src"],
      "@hl/privateer-agent-sdk": ["./packages/agent-sdk/src"],
      "@hl/privateer-hl-client": ["./packages/hl-client/src"],
      "@hl/privateer-runtime": ["./apps/runtime/src"],
      "@hl/privateer-api": ["./apps/api/src"],
      "@hl/privateer-ws-gateway": ["./apps/ws-gateway/src"],
      "@hl/privateer-web": ["./apps/web/src"]
    }
  }
}
