    "@opentelemetry/resources": "^1.30.0",
    "@opentelemetry/sdk-node": "^0.57.1",
    "@opentelemetry/semantic-conventions": "^1.30.0",
    "ioredis": "^5.5.0",
    "pg": "^8.16.3",
    "prom-client": "^15.1.3",
    "ulid": "^2.3.0",
