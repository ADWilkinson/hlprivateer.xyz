  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "bunx tsx watch src/index.ts",
    "build": "bunx tsc -p tsconfig.json",
